# =============================================================================
# Finowa - Variables de Entorno
# =============================================================================
# Copia este archivo a .env y completa los valores.
# En Vercel, agrega TODAS estas variables en Settings > Environment Variables.
# =============================================================================

# --- Base de datos ---
# Local: SQLite (desarrollo)
DATABASE_URL="file:./prisma/dev.db"

# Produccion: Turso Cloud (libSQL remoto)
# TURSO_DATABASE_URL="libsql://finowa-wilvm2001.aws-us-east-1.turso.io"
# TURSO_AUTH_TOKEN="eyJhbGciOiJ..."

# --- Autenticacion (OBLIGATORIO en produccion) ---
# Genera un secreto con: openssl rand -base64 32
AUTH_SECRET="finanza-super-secret-key-2024-must-be-at-least-32-chars"

# --- URL publica de la app ---
# En desarrollo: http://localhost:3000
# En Vercel: https://tu-app.vercel.app (la URL que asigna Vercel)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
